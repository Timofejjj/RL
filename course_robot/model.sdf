<?xml version="1.0" ?>
<!--
  Длинные стойки до пола в Gazebo — часть ваших STL (стойки/шарики), не баг движка.
  В дереве не будет «base_box» — убран искусственный collision-куб (он только путал настройку).
  RViz читает course_robot.urdf — при смене pose здесь синхронизируйте URDF (см. комментарий в .urdf).
-->
<!-- SDF 1.9: явные фреймы (__model__, relative_to), иначе в gz-sim колёса с pose в фрейме модели + joint к base_link часто «разъезжаются». -->
<sdf version="1.9">
  <model name="course_robot">
    <static>false</static>
    <!-- Поворот делаем на уровне визуала/корпуса (см. base_link visual/collision), чтобы колёса остались как были. -->
    <pose>0 0 0 0 0 0</pose>
    <link name="course_robot_base_link">
      <!-- Совпадает с child_frame_id DiffDrive и корневым линком в course_robot.urdf (RViz без TF Prefix). -->
      <!-- Лёгкий сдвиг, если в CAD низ деталей ниже нуля link. Корпус «висит» — уменьшите z (например 0.05). -->
      <pose relative_to="__model__">0 0 -0.02 0 0 0</pose>
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.2</ixx>
          <iyy>0.2</iyy>
          <izz>0.2</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Простейшая коллизия корпуса (без STL) -->
      <collision name="chassis_col">
        <pose>0 0 0.12 0 0 1.5708</pose>
        <geometry>
          <box>
            <size>0.38 0.20 0.24</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="platforma">
        <pose>0 0 0 0 0 1.5708</pose>
        <material>
          <ambient>0.48 0.48 0.5 1</ambient>
          <diffuse>0.62 0.62 0.65 1</diffuse>
          <specular>0.25 0.25 0.27 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/Platforma.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <visual name="etaj_2">
        <!-- Подъём только этого меша вдоль Z base_link (м). Больше — увеличьте третье число. -->
        <pose>0 0 0.1 0 0 1.5708</pose>
        <material>
          <ambient>0.48 0.48 0.5 1</ambient>
          <diffuse>0.62 0.62 0.65 1</diffuse>
          <specular>0.25 0.25 0.27 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/etaj_2.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <visual name="motor_leviy">
        <pose>0 0 0 0 0 1.5708</pose>
        <material>
          <ambient>0.4 0.4 0.42 1</ambient>
          <diffuse>0.5 0.5 0.52 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/Motor_leviy.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <visual name="motor_praviy">
        <pose>0 0 0 0 0 1.5708</pose>
        <material>
          <ambient>0.4 0.4 0.42 1</ambient>
          <diffuse>0.5 0.5 0.52 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/Motor_praviy.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <visual name="sharik_levo">
        <pose>0 0 0 0 0 1.5708</pose>
        <material>
          <ambient>0.35 0.35 0.38 1</ambient>
          <diffuse>0.45 0.45 0.48 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/Sharik_levo.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <visual name="sharik_niz">
        <pose>0 0 0 0 0 1.5708</pose>
        <material>
          <ambient>0.35 0.35 0.38 1</ambient>
          <diffuse>0.45 0.45 0.48 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/Sharik_niz.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
      <visual name="sharik_pravo">
        <pose>0 0 0 0 0 1.5708</pose>
        <material>
          <ambient>0.35 0.35 0.38 1</ambient>
          <diffuse>0.45 0.45 0.48 1</diffuse>
          <specular>0.15 0.15 0.15 1</specular>
        </material>
        <geometry>
          <mesh>
            <uri>model://course_robot/meshes/Sharik_pravo.STL</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- Физические колёса: цилиндр roll 90° (ось вдоль Y), revolute вокруг Y; z — центр колеса от base_link. -->
    <link name="left_wheel">
      <pose relative_to="course_robot_base_link">0 0.11 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.0006</ixx>
          <iyy>0.0006</iyy>
          <izz>0.0006</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="left_wheel_col">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.2</mu>
              <mu2>1.2</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="left_wheel_vis">
        <pose>0 0 0 1.5708 0 0</pose>
        <material>
          <ambient>0.85 0.1 0.1 1</ambient>
          <diffuse>0.9 0.15 0.15 1</diffuse>
        </material>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <link name="right_wheel">
      <pose relative_to="course_robot_base_link">0 -0.11 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.0006</ixx>
          <iyy>0.0006</iyy>
          <izz>0.0006</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="right_wheel_col">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.2</mu>
              <mu2>1.2</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="right_wheel_vis">
        <pose>0 0 0 1.5708 0 0</pose>
        <material>
          <ambient>0.1 0.85 0.1 1</ambient>
          <diffuse>0.15 0.9 0.15 1</diffuse>
        </material>
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.02</length>
          </cylinder>
        </geometry>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>course_robot_base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>course_robot_base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 1 0</xyz>
      </axis>
    </joint>

    <!-- 3D lidar отдельным линком на "капоте" робота -->
    <link name="lidar_link">
      <pose relative_to="course_robot_base_link">-0.05 0 0.15 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <iyy>0.00001</iyy>
          <izz>0.00001</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      
      <visual name="lidar_vis">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.05</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>1.0 1.0 0.0 1</ambient>
          <diffuse>1.0 1.0 0.0 1</diffuse>
        </material>
      </visual>

      <sensor name="lidar_3d" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <visualize>true</visualize>

        <ray>
          <scan>
            <horizontal>
              <samples>240</samples>
              <min_angle>-1.57</min_angle>
              <max_angle>1.57</max_angle>
            </horizontal>
            <vertical>
              <samples>10</samples>
              <min_angle>-0.20</min_angle>
              <max_angle>0.10</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.02</min>
            <max>20.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
      </sensor>
    </link>

    <!-- IMU отдельным линком для LIO-SAM -->
    <link name="imu_link">
      <pose relative_to="course_robot_base_link">0 0 0.10 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia>
          <!-- Небольшой "кубик" ~2см: I = 1/12*m*(b^2+c^2) -->
          <ixx>0.00000067</ixx>
          <iyy>0.00000067</iyy>
          <izz>0.00000067</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <sensor name="imu" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>100</update_rate>

        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.0002</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.002</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.002</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.002</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>course_robot_base_link</parent>
      <child>imu_link</child>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <parent>course_robot_base_link</parent>
      <child>lidar_link</child>
    </joint>

    <!-- Дифференциальный привод: публикует odometry и принимает cmd_vel -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.22</wheel_separation>
      <wheel_radius>0.04</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <!-- В ROS TF odom→base публикует odom_to_tf.py; мост /tf из gz отключён (см. ros_gz_course_robot.yaml). -->
      <publish_tf>false</publish_tf>
      <!-- Уникальные имена, чтобы не пересекаться с vehicle_blue / другими base_link в RViz -->
      <odom_frame_id>course_robot_odom</odom_frame_id>
      <child_frame_id>course_robot_base_link</child_frame_id>
      <!-- cmd_vel: /model/<model_name>/cmd_vel -->
    </plugin>

    <!-- Sensors (gz-sim-sensors-system) должен быть один на мир — см. course_robot_world.sdf.
         Второй экземпляр на модели даёт Ogre::ItemIdentityException (PbsMaterialsShadowNode already exists). -->
  </model>
</sdf>
